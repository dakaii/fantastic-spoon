[Interface]
Address = {{ wg_server_address | default('10.66.0.1/24') }}
ListenPort = {{ wireguard_port | default(51820) }}
PrivateKey = {{ wg_server_private_key }}
PostUp = iptables -A FORWARD -i %i -j ACCEPT; iptables -A FORWARD -o %i -j ACCEPT; iptables -t nat -A POSTROUTING -o {{ wg_uplink.stdout }} -j MASQUERADE
PostDown = iptables -D FORWARD -i %i -j ACCEPT; iptables -D FORWARD -o %i -j ACCEPT; iptables -t nat -D POSTROUTING -o {{ wg_uplink.stdout }} -j MASQUERADE

{% if wg_peers is defined and wg_peers | length > 0 %}
{% for peer in wg_peers %}
[Peer]
# client={{ peer.name }}
PublicKey = {{ peer.public_key }}
AllowedIPs = {{ peer.address }}

{% endfor %}
{% else %}
{# Legacy single-peer (pre multi-peer scripts) #}
[Peer]
# client={{ wg_client_name | default('laptop') }}
PublicKey = {{ wg_client_public_key }}
AllowedIPs = {{ wg_client_address | default('10.66.0.2/32') }}
{% endif %}
