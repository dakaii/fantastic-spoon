# Copy to terraform.tfvars:
#   cp terraform.tfvars.example terraform.tfvars
#
# Reuse gcp_project / ssh_public_key / admin_cidr from primary — but do NOT copy
# primary-cluster-gcp/terraform.tfvars wholesale (extra vars cause warnings).
# Prefer: GCP_PROJECT=hybrid-k8s-dev ./scripts/gcp-deploy.sh init
#   which writes a clean vpn-gateways-gcp/terraform.tfvars
#
# This stack is isolated (own VPC + state) and does not modify primary/standby.

gcp_project = "your-gcp-project-id"
# Per-city map (scripts/vpn-city-lib.sh): us→us-central1, hk→asia-east2
gcp_region  = "us-central1"
gcp_zone    = "us-central1-a"

project_name = "hybrid-k8s"
city         = "us"
# Second city example:
# city         = "hk"
# gcp_region   = "asia-east2"
# gcp_zone     = "asia-east2-a"
# subnet_cidr  = "10.50.1.0/24"
#
# Each city has its own GCS TF state: vpn-gateways-gcp/<city>/terraform.tfstate
# Prefer: VPN_CITY=hk ./scripts/gcp-deploy.sh vpn  (or GHA city=hk)

ssh_public_key = "ssh-ed25519 AAAA... you@host"
admin_cidr     = "203.0.113.10/32"

# Optional: allow WG from additional CIDRs (phones on cellular, etc.)
# vpn_client_cidrs = ["203.0.113.10/32", "198.51.100.0/24"]

# CIDRs allowed to scrape node_exporter :9100 (empty = admin_cidr).
# IMPORTANT: if admin_cidr is 0.0.0.0/0 for GHA SSH, metrics inherit that unless set here.
# For in-cluster Prometheus, add all primary node public NAT IPs (CP + workers):
#   terraform -chdir=../primary-cluster-gcp output -json primary_public_ips
# vpn_metrics_cidrs = ["34.x.x.x/32", "34.y.y.y/32"]

machine_type      = "e2-small"
wireguard_port    = 51820
reserve_static_ip = true
