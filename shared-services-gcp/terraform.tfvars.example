# Copy to terraform.tfvars:
# cp terraform.tfvars.example terraform.tfvars

gcp_project = "your-gcp-project-id"
gcp_region  = "us-central1"

project_name = "hybrid-k8s"

# Leave empty until you register a domain (Phase 4)
domain_name   = ""
app_subdomain = "app"

# Witness + Firestore (Phase 4). Set create_firestore_database=false if project already has one.
enable_witness            = true
create_firestore_database = true

# Level C automation (default off). Requires:
#   1. ./scripts/seed-standby-kubeconfig.sh
#   2. standby k3s_api_source_ranges open for CF egress (lab 0.0.0.0/0)
# enable_level_c_automation = true
# standby_kubeconfig_secret_id = "hybrid-k8s-standby-kubeconfig"

# Paths to cluster Terraform state (defaults work after primary + standby apply)
# primary_state_path = "../primary-cluster-gcp/terraform.tfstate"
# standby_state_path = "../cloud-services-gcp/terraform.tfstate"
